DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/onboarding
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/onboarding_test
DEBUG=false

# Integration call resilience (timeout, retry, fallback chain)
INTEGRATION_TIMEOUT_SECONDS=5.0
INTEGRATION_MAX_ATTEMPTS=3
INTEGRATION_RETRY_BACKOFF_SECONDS=0.25
INTEGRATION_RETRY_BACKOFF_MULTIPLIER=2.0
INTEGRATION_MAX_BACKOFF_SECONDS=2.0
